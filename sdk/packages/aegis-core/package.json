{
  "name": "@junaadh/aegis",
  "version": "0.1.0",
  "description": "Core TypeScript client for the Aegis auth server",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "homepage": "https://github.com/junaadh/aegis#readme",
  "bugs": {
    "url": "https://github.com/junaadh/aegis/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junaadh/aegis.git",
    "directory": "sdk/packages/aegis-core"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test ./test"
  }
}
