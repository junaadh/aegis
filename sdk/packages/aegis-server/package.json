{
  "name": "@junaadh/aegis-server",
  "version": "0.1.0",
  "description": "Server-side helpers for integrating with the Aegis auth server",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "homepage": "https://github.com/junaadh/aegis#readme",
  "bugs": {
    "url": "https://github.com/junaadh/aegis/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junaadh/aegis.git",
    "directory": "sdk/packages/aegis-server"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "typecheck": "bun run --filter @junaadh/aegis build && bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test ./test"
  },
  "dependencies": {
    "@junaadh/aegis": "0.1.0"
  },
  "peerDependencies": {
    "next": "^16.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.22",
    "next": "16.2.4"
  }
}
