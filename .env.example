# =============================================================================
# Aegis dev environment
# Copy to .env and adjust as needed
# =============================================================================

# --- Postgres ---
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis
POSTGRES_DB=aegis_dev
POSTGRES_PORT=5436

# --- Redis ---
REDIS_PORT=6380

# --- Mailpit ---
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# --- Aegis app (read by aegis.toml via env: references) ---
AEGIS_SESSION_SECRET=
AEGIS_DATABASE_URL=postgresql://aegis:aegis@localhost:5436/aegis_dev
AEGIS_DATABASE_ENCRYPTION_KEY=
AEGIS_REDIS_URL=redis://localhost:6380

AEGIS_EMAIL_FROM_ADDRESS=
AEGIS_EMAIL_SMTP_HOST=
AEGIS_EMAIL_SMTP_PORT=
AEGIS_EMAIL_SMTP_USERNAME=
AEGIS_EMAIL_SMTP_PASSWORD=

AEGIS_API_INTERNAL_TOKEN=
AEGIS_CRYPTO_MASTER_KEY=
AEGIS_CRYPTO_JWT_PRIVATE_KEY=
