{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config",
  "type": "object",
  "properties": {
    "api": {
      "default": {
        "internal": {
          "allowed_cidrs": [],
          "api_token": null
        },
        "metadata_allowed_keys": [],
        "rate_limit": {
          "burst": 10,
          "enabled": true,
          "requests_per_minute": 60
        }
      },
      "allOf": [
        {
          "$ref": "#/definitions/ApiConfig"
        }
      ]
    },
    "compliance": {
      "default": {
        "data_retention": {
          "audit_log_days": 2555,
          "deleted_user_anonymize_after_days": 0,
          "guest_ttl_days": 30
        },
        "deletion": {
          "anonymize_email_pattern": "deleted-{hash}@anonymized.local",
          "preserve_referential_integrity": true
        }
      },
      "allOf": [
        {
          "$ref": "#/definitions/ComplianceConfig"
        }
      ]
    },
    "credentials": {
      "default": {
        "mfa": {
          "totp": {
            "algorithm": "SHA1",
            "digits": 6,
            "issuer": "",
            "period": 30,
            "recovery_codes": {
              "code_length": 12,
              "count": 10
            },
            "skew": 1
          }
        },
        "passkeys": {
          "origins": [],
          "resident_key": "preferred",
          "rp_id": "",
          "rp_name": "",
          "timeout_seconds": 60,
          "user_verification": "preferred"
        },
        "password": {
          "argon2": {
            "memory_cost": 65536,
            "parallelism": 2,
            "time_cost": 3
          },
          "hashing_algorithm": "argon2id",
          "policy": {
            "disallow_common": true,
            "min_length": 12,
            "require_digit": true,
            "require_lowercase": true,
            "require_symbol": true,
            "require_uppercase": true
          }
        }
      },
      "allOf": [
        {
          "$ref": "#/definitions/CredentialsConfig"
        }
      ]
    },
    "crypto": {
      "default": {
        "jwt": {
          "algorithm": "RS256",
          "audience": null,
          "enabled": false,
          "issuer": null,
          "private_key": null,
          "public_key": null
        },
        "master_key": null
      },
      "allOf": [
        {
          "$ref": "#/definitions/CryptoConfig"
        }
      ]
    },
    "database": {
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/DatabaseConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "email": {
      "default": {
        "enabled": false,
        "from_address": "",
        "from_name": "",
        "password_reset_token_ttl_minutes": 60,
        "smtp": {
          "host": "",
          "password": "",
          "port": 587,
          "starttls": true,
          "timeout_seconds": 30,
          "username": ""
        },
        "templates": {
          "password_reset": "",
          "verification": ""
        },
        "verification_token_ttl_hours": 24
      },
      "allOf": [
        {
          "$ref": "#/definitions/EmailConfig"
        }
      ]
    },
    "redis": {
      "default": {
        "enabled": false,
        "max_connections": 10,
        "url": "redis://127.0.0.1:6379/0"
      },
      "allOf": [
        {
          "$ref": "#/definitions/RedisConfig"
        }
      ]
    },
    "server": {
      "default": {
        "host": "0.0.0.0",
        "log_format": "json",
        "log_level": "info",
        "log_output": [
          "stdout"
        ],
        "port": 8080,
        "public_url": null,
        "tls_cert": null,
        "tls_key": null
      },
      "allOf": [
        {
          "$ref": "#/definitions/ServerConfig"
        }
      ]
    },
    "session": {
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/SessionConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "webhooks": {
      "default": {
        "enabled": false,
        "endpoints": []
      },
      "allOf": [
        {
          "$ref": "#/definitions/WebhooksConfig"
        }
      ]
    }
  },
  "additionalProperties": false,
  "x-tombi-toml-version": "1.0.0",
  "definitions": {
    "ApiConfig": {
      "type": "object",
      "properties": {
        "internal": {
          "default": {
            "allowed_cidrs": [],
            "api_token": null
          },
          "allOf": [
            {
              "$ref": "#/definitions/InternalApiConfig"
            }
          ]
        },
        "metadata_allowed_keys": {
          "title": "Allowed metadata keys",
          "description": "Allowlist of metadata keys users can set.",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rate_limit": {
          "default": {
            "burst": 10,
            "enabled": true,
            "requests_per_minute": 60
          },
          "allOf": [
            {
              "$ref": "#/definitions/RateLimitConfig"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "Argon2Config": {
      "type": "object",
      "properties": {
        "memory_cost": {
          "title": "Memory cost",
          "description": "Argon2 memory cost in KiB.",
          "default": 65536,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "parallelism": {
          "title": "Parallelism",
          "description": "Argon2 parallelism parameter.",
          "default": 2,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "time_cost": {
          "title": "Time cost",
          "description": "Argon2 time cost parameter.",
          "default": 3,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "BearerConfig": {
      "type": "object",
      "properties": {
        "default_ttl_minutes": {
          "title": "Default TTL",
          "description": "Default bearer token TTL in minutes.",
          "default": 15,
          "type": "integer",
          "minimum": 0.0
        },
        "opaque_token_length": {
          "title": "Token length",
          "description": "Length of opaque bearer tokens in bytes.",
          "default": 32,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "refresh_token_enabled": {
          "title": "Refresh tokens",
          "description": "Enable refresh token flow.",
          "default": false,
          "type": "boolean"
        },
        "refresh_token_ttl_days": {
          "title": "Refresh TTL",
          "description": "Refresh token TTL in days.",
          "default": 30,
          "type": "integer",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "ComplianceConfig": {
      "type": "object",
      "properties": {
        "data_retention": {
          "default": {
            "audit_log_days": 2555,
            "deleted_user_anonymize_after_days": 0,
            "guest_ttl_days": 30
          },
          "allOf": [
            {
              "$ref": "#/definitions/DataRetentionConfig"
            }
          ]
        },
        "deletion": {
          "default": {
            "anonymize_email_pattern": "deleted-{hash}@anonymized.local",
            "preserve_referential_integrity": true
          },
          "allOf": [
            {
              "$ref": "#/definitions/DeletionConfig"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "CookieConfig": {
      "type": "object",
      "properties": {
        "domain": {
          "title": "Cookie domain",
          "description": "Domain for the cookie.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "http_only": {
          "title": "HTTP only",
          "description": "Prevent JavaScript access to cookie.",
          "default": true,
          "type": "boolean"
        },
        "name": {
          "title": "Cookie name",
          "description": "Name of the session cookie.",
          "default": "aegis_session",
          "type": "string"
        },
        "path": {
          "title": "Cookie path",
          "description": "URL path for the cookie.",
          "default": "/",
          "type": "string"
        },
        "same_site": {
          "title": "SameSite",
          "description": "Cookie SameSite policy.",
          "default": "lax",
          "allOf": [
            {
              "$ref": "#/definitions/SameSite"
            }
          ]
        },
        "secure": {
          "title": "Secure",
          "description": "Only send cookie over HTTPS.",
          "default": true,
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "CredentialsConfig": {
      "type": "object",
      "properties": {
        "mfa": {
          "default": {
            "totp": {
              "algorithm": "SHA1",
              "digits": 6,
              "issuer": "",
              "period": 30,
              "recovery_codes": {
                "code_length": 12,
                "count": 10
              },
              "skew": 1
            }
          },
          "allOf": [
            {
              "$ref": "#/definitions/MfaConfig"
            }
          ]
        },
        "passkeys": {
          "default": {
            "origins": [],
            "resident_key": "preferred",
            "rp_id": "",
            "rp_name": "",
            "timeout_seconds": 60,
            "user_verification": "preferred"
          },
          "allOf": [
            {
              "$ref": "#/definitions/PasskeysConfig"
            }
          ]
        },
        "password": {
          "default": {
            "argon2": {
              "memory_cost": 65536,
              "parallelism": 2,
              "time_cost": 3
            },
            "hashing_algorithm": "argon2id",
            "policy": {
              "disallow_common": true,
              "min_length": 12,
              "require_digit": true,
              "require_lowercase": true,
              "require_symbol": true,
              "require_uppercase": true
            }
          },
          "allOf": [
            {
              "$ref": "#/definitions/PasswordConfig"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "CryptoConfig": {
      "type": "object",
      "properties": {
        "jwt": {
          "default": {
            "algorithm": "RS256",
            "audience": null,
            "enabled": false,
            "issuer": null,
            "private_key": null,
            "public_key": null
          },
          "allOf": [
            {
              "$ref": "#/definitions/JwtConfig"
            }
          ]
        },
        "master_key": {
          "title": "Master key",
          "description": "Master encryption key. Use env:VAR or file:/path reference.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "DataRetentionConfig": {
      "type": "object",
      "properties": {
        "audit_log_days": {
          "title": "Audit log retention",
          "description": "Days to retain audit logs (~7 years = 2555).",
          "default": 2555,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "deleted_user_anonymize_after_days": {
          "title": "Anonymize after",
          "description": "Days after deletion to anonymize user data (0 = immediate).",
          "default": 0,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "guest_ttl_days": {
          "title": "Guest TTL",
          "description": "Days before expired guests are purged.",
          "default": 30,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "DatabaseConfig": {
      "type": "object",
      "required": [
        "url"
      ],
      "properties": {
        "connection_timeout_seconds": {
          "title": "Connection timeout",
          "description": "Connection timeout in seconds.",
          "default": 30,
          "type": "integer",
          "minimum": 0.0
        },
        "encryption_key": {
          "title": "Encryption key",
          "description": "Key for encrypting sensitive columns. Use env:VAR or file:/path references.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "max_connections": {
          "title": "Max connections",
          "description": "Maximum number of database connections.",
          "default": 25,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "min_idle": {
          "title": "Min idle",
          "description": "Minimum number of idle connections.",
          "default": 5,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "url": {
          "title": "Database URL",
          "description": "PostgreSQL connection string.",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "DeletionConfig": {
      "type": "object",
      "properties": {
        "anonymize_email_pattern": {
          "title": "Anonymize pattern",
          "description": "Pattern for anonymized emails. Use {hash} as placeholder.",
          "default": "deleted-{hash}@anonymized.local",
          "type": "string"
        },
        "preserve_referential_integrity": {
          "title": "Preserve referential integrity",
          "description": "Keep anonymized records for referential integrity.",
          "default": true,
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "EmailConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "title": "Enabled",
          "description": "Enable email delivery.",
          "default": false,
          "type": "boolean"
        },
        "from_address": {
          "title": "From address",
          "description": "Sender email address.",
          "default": "",
          "type": "string"
        },
        "from_name": {
          "title": "From name",
          "description": "Sender display name.",
          "default": "",
          "type": "string"
        },
        "password_reset_token_ttl_minutes": {
          "title": "Password reset token TTL (minutes)",
          "description": "How long password reset tokens remain valid.",
          "default": 60,
          "type": "integer",
          "minimum": 0.0
        },
        "smtp": {
          "default": {
            "host": "",
            "password": "",
            "port": 587,
            "starttls": true,
            "timeout_seconds": 30,
            "username": ""
          },
          "allOf": [
            {
              "$ref": "#/definitions/SmtpConfig"
            }
          ]
        },
        "templates": {
          "default": {
            "password_reset": "",
            "verification": ""
          },
          "allOf": [
            {
              "$ref": "#/definitions/EmailTemplatesConfig"
            }
          ]
        },
        "verification_token_ttl_hours": {
          "title": "Verification token TTL (hours)",
          "description": "How long email verification tokens remain valid.",
          "default": 24,
          "type": "integer",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "EmailTemplatesConfig": {
      "type": "object",
      "properties": {
        "password_reset": {
          "title": "Password reset template",
          "description": "Path to password reset template.",
          "default": "",
          "type": "string"
        },
        "verification": {
          "title": "Verification template",
          "description": "Path to email verification template.",
          "default": "",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "HashingAlgorithm": {
      "type": "string",
      "enum": [
        "argon2id"
      ]
    },
    "InternalApiConfig": {
      "type": "object",
      "properties": {
        "allowed_cidrs": {
          "title": "Allowed CIDRs",
          "description": "Network ranges allowed for internal API access.",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "api_token": {
          "title": "API token",
          "description": "Static token for service-to-service auth. Use env:VAR reference.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "JwtAlgorithm": {
      "type": "string",
      "enum": [
        "RS256",
        "ES256",
        "HS256"
      ]
    },
    "JwtConfig": {
      "type": "object",
      "properties": {
        "algorithm": {
          "title": "Algorithm",
          "description": "JWT signing algorithm.",
          "default": "RS256",
          "allOf": [
            {
              "$ref": "#/definitions/JwtAlgorithm"
            }
          ]
        },
        "audience": {
          "title": "Audience",
          "description": "JWT audience claim.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "title": "Enabled",
          "description": "Enable JWT-based stateless authentication.",
          "default": false,
          "type": "boolean"
        },
        "issuer": {
          "title": "Issuer",
          "description": "JWT issuer claim.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "private_key": {
          "title": "Private key",
          "description": "Path or reference to JWT private key.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "public_key": {
          "title": "Public key",
          "description": "Path or reference to JWT public key.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "LogFormat": {
      "type": "string",
      "enum": [
        "json",
        "text"
      ]
    },
    "LogLevel": {
      "type": "string",
      "enum": [
        "info",
        "debug",
        "warn",
        "error"
      ]
    },
    "MfaConfig": {
      "type": "object",
      "properties": {
        "totp": {
          "default": {
            "algorithm": "SHA1",
            "digits": 6,
            "issuer": "",
            "period": 30,
            "recovery_codes": {
              "code_length": 12,
              "count": 10
            },
            "skew": 1
          },
          "allOf": [
            {
              "$ref": "#/definitions/TotpConfig"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "PasskeysConfig": {
      "type": "object",
      "properties": {
        "origins": {
          "title": "Origins",
          "description": "Allowed origins for WebAuthn.",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resident_key": {
          "title": "Resident key",
          "description": "WebAuthn resident key requirement.",
          "default": "preferred",
          "allOf": [
            {
              "$ref": "#/definitions/ResidentKey"
            }
          ]
        },
        "rp_id": {
          "title": "Relying party ID",
          "description": "WebAuthn relying party identifier.",
          "default": "",
          "type": "string"
        },
        "rp_name": {
          "title": "Relying party name",
          "description": "Human-readable relying party name.",
          "default": "",
          "type": "string"
        },
        "timeout_seconds": {
          "title": "Timeout",
          "description": "WebAuthn ceremony timeout in seconds.",
          "default": 60,
          "type": "integer",
          "minimum": 0.0
        },
        "user_verification": {
          "title": "User verification",
          "description": "WebAuthn user verification requirement.",
          "default": "preferred",
          "allOf": [
            {
              "$ref": "#/definitions/UserVerification"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "PasswordConfig": {
      "type": "object",
      "properties": {
        "argon2": {
          "default": {
            "memory_cost": 65536,
            "parallelism": 2,
            "time_cost": 3
          },
          "allOf": [
            {
              "$ref": "#/definitions/Argon2Config"
            }
          ]
        },
        "hashing_algorithm": {
          "title": "Hashing algorithm",
          "description": "Password hashing algorithm.",
          "default": "argon2id",
          "allOf": [
            {
              "$ref": "#/definitions/HashingAlgorithm"
            }
          ]
        },
        "policy": {
          "default": {
            "disallow_common": true,
            "min_length": 12,
            "require_digit": true,
            "require_lowercase": true,
            "require_symbol": true,
            "require_uppercase": true
          },
          "allOf": [
            {
              "$ref": "#/definitions/PasswordPolicyConfig"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "PasswordPolicyConfig": {
      "type": "object",
      "properties": {
        "disallow_common": {
          "title": "Disallow common",
          "description": "Disallow commonly used passwords.",
          "default": true,
          "type": "boolean"
        },
        "min_length": {
          "title": "Minimum length",
          "description": "Minimum password length.",
          "default": 12,
          "type": "integer",
          "minimum": 0.0
        },
        "require_digit": {
          "title": "Require digit",
          "description": "Require at least one digit.",
          "default": true,
          "type": "boolean"
        },
        "require_lowercase": {
          "title": "Require lowercase",
          "description": "Require at least one lowercase letter.",
          "default": true,
          "type": "boolean"
        },
        "require_symbol": {
          "title": "Require symbol",
          "description": "Require at least one symbol.",
          "default": true,
          "type": "boolean"
        },
        "require_uppercase": {
          "title": "Require uppercase",
          "description": "Require at least one uppercase letter.",
          "default": true,
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "RateLimitConfig": {
      "type": "object",
      "properties": {
        "burst": {
          "title": "Burst",
          "description": "Burst capacity for rate limiter.",
          "default": 10,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "enabled": {
          "title": "Enabled",
          "description": "Enable rate limiting.",
          "default": true,
          "type": "boolean"
        },
        "requests_per_minute": {
          "title": "Requests per minute",
          "description": "Maximum requests per minute per client.",
          "default": 60,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "RecoveryCodesConfig": {
      "type": "object",
      "properties": {
        "code_length": {
          "title": "Code length",
          "description": "Length of each recovery code.",
          "default": 12,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "count": {
          "title": "Count",
          "description": "Number of recovery codes to generate.",
          "default": 10,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "RedisConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "title": "Enabled",
          "description": "Enable Redis for caching and rate limiting.",
          "default": false,
          "type": "boolean"
        },
        "max_connections": {
          "title": "Max connections",
          "description": "Maximum number of Redis connections.",
          "default": 10,
          "type": "integer",
          "maximum": 4294967295.0,
          "minimum": 0.0
        },
        "url": {
          "title": "Redis URL",
          "description": "Redis connection string.",
          "default": "redis://127.0.0.1:6379/0",
